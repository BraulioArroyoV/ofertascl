# =============================================
# OfertasCL - Variables de Entorno
# =============================================
# Copia este archivo como .env y completa los valores

# MercadoLibre API (obtener en https://developers.mercadolibre.cl)
ML_APP_ID=TU_APP_ID_AQUI
ML_SECRET=TU_SECRET_AQUI
ML_ACCESS_TOKEN=TU_ACCESS_TOKEN_AQUI

# Tu usuario de afiliados MercadoLibre
ML_AFFILIATE_ID=ARROYOBRAULIO20230821195606

# Puerto del servidor backend
PORT=3001

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# =============================================
# FUTURA INTEGRACION - Completar cuando tengas cuentas
# =============================================

# AliExpress Affiliates (https://portals.aliexpress.com)
# ALIEXPRESS_APP_KEY=
# ALIEXPRESS_APP_SECRET=
# ALIEXPRESS_TRACKING_ID=

# Soicos (red de afiliados Chile)
# SOICOS_API_KEY=

# Google Analytics (tracking de visitas)
# VITE_GA_ID=

# =============================================
# PRODUCCION (Vercel / Railway / Render)
# =============================================
# NODE_ENV=production
# FRONTEND_URL=https://ofertascl.cl
